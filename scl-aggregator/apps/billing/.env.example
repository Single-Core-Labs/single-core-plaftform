# ── SCL Billing Service ────────────────────────────
# Copy this to .env.local and fill in your values

# Server
PORT=8003
NODE_ENV=development

# Database (Supabase Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/scl_billing?schema=public"

# Stripe (USD payments)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_SUCCESS_URL="https://dashboard.singlecorelabs.in/credits?status=success"
STRIPE_CANCEL_URL="https://dashboard.singlecorelabs.in/credits?status=cancelled"

# Razorpay (INR payments)
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."
RAZORPAY_WEBHOOK_SECRET="..."

# Internal auth (gateway → billing)
INTERNAL_API_SECRET="scl-internal-secret-change-me"
