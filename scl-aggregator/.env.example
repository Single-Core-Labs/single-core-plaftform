# SCL Model Aggregator - Local Environment Configuration
# Copy this file to .env and fill in the values before running `docker-compose up`

# ── General ──────────────────────────────────────────────────
ENVIRONMENT=dev

# ── Gateway Service (Rust, :8000) ────────────────────────────
GATEWAY_PORT=8000
ROUTER_URL=http://router:8001
CACHE_URL=http://cache:8002
BILLING_URL=http://billing:8003
INTERNAL_API_SECRET=scl-internal-dev-secret

# ── Router Service (Python, :8001) ───────────────────────────
ROUTER_PORT=8001
# Fallback keys for adapters (if users don't provide their own)
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AIzaSy...
GROQ_API_KEY=gsk_...
TOGETHER_API_KEY=...

# ── Cache Service (Python, :8002) ────────────────────────────
CACHE_PORT=8002
REDIS_HOST=redis
REDIS_PORT=6379
CHROMADB_HOST=chromadb
CHROMADB_PORT=8004

# ── Billing Service (Node, :8003) ────────────────────────────
BILLING_PORT=8003
DATABASE_URL=postgresql://scl_user:scl_password@postgres:5432/scl_billing?schema=public
# Stripe/Razorpay (Optional for local dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# ── Dashboard (Next.js, :3000) ───────────────────────────────
DASHBOARD_PORT=3000
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
NEXT_PUBLIC_BILLING_URL=http://localhost:8003
